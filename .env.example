# MyClaw runtime-owned local secrets.
#
# Copy to <MYCLAW_HOME>/.env for local/personal mode. Non-secret settings
# belong in <MYCLAW_HOME>/settings.yaml, not here. Agent-accessed provider
# credentials such as ANTHROPIC_API_KEY, OPENAI_API_KEY, and
# CLAUDE_CODE_OAUTH_TOKEN must be configured through the credential broker.

# Runtime root for MyClaw local state. Default when unset: ~/myclaw.
# Local provider artifacts are stored under <MYCLAW_HOME>/artifacts/.
# Do not set CLAUDE_CONFIG_DIR here; MyClaw creates it per Claude run.
MYCLAW_HOME=

# Runtime Postgres database URL. The configured settings.yaml key is
# storage.postgres.url_env, which defaults to MYCLAW_DATABASE_URL.
MYCLAW_DATABASE_URL=postgres://myclaw:change-me@127.0.0.1:5432/myclaw?schema=myclaw

# OneCLI broker persistence. Use a different Postgres role from
# MYCLAW_DATABASE_URL and keep schema=onecli.
ONECLI_DATABASE_URL=postgres://onecli:change-me@127.0.0.1:5432/myclaw?schema=onecli

# Base64-encoded 32-byte key for local OneCLI broker secret encryption.
SECRET_ENCRYPTION_KEY=

# Stable IPC signing secret. Generate a high-entropy value for production.
MYCLAW_IPC_AUTH_SECRET=

# Channel runtime secrets. Fill only for enabled channels.
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Optional runtime-only operational knobs.
LOG_LEVEL=info
REMOTE_CONTROL_AUTO_ACCEPT=false
CHROME_PATH=
